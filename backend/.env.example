# =============================================================================
# .env — Environment variables for Football Vision AI backend
#
# Setup:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values below.
#   3. NEVER commit .env to git.
# =============================================================================

# ── Kaggle API credentials ──────────────────────────────────────────────────
# Get yours at: https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=
KAGGLE_KEY=

# ── Roboflow API key (optional — only needed for --source roboflow) ─────────
# Get yours at: https://app.roboflow.com → Settings → API
RF_API_KEY=
